# Sniper Security Platform Environment Configuration
# Copy this file to .env.local for local development

# Server Configuration
PORT=3004
NEXT_PUBLIC_PORT=3004

# Sniper Paths (Docker defaults - change for local development)
SNIPER_PATH=/usr/share/sniper/sniper
LOOT_PATH=/usr/share/sniper/loot
WORKSPACE_PATH=/usr/share/sniper/loot/workspace

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://sniper:sniper@localhost:5433/sniper
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=sniper
POSTGRES_PASSWORD=sniper
POSTGRES_DB=sniper

# Redis Configuration
REDIS_URL=redis://localhost:6379

# API Keys (Add your own keys)
SHODAN_API_KEY=
CENSYS_APP_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=

# Development
NODE_ENV=production
